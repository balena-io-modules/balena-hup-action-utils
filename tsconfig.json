{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2017",
    "lib": [
        "es2019"
    ],
    "outDir": "build",
    "declaration": true,
    "esModuleInterop": true,
    "importHelpers": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "preserveConstEnums": true,
    "pretty": true,
    "sourceMap": true,
    "strictNullChecks": true
  },
  "include": [
    "lib/**/*.ts"
  ]
}
